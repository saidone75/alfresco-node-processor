{
  "collector": {
    "name": "QueryNodeCollector",
    "args": {
      "query": "TYPE:'cm:folder' AND PATH:'/app:company_home/*'"
    }
  },
  "processor": {
    "name": "AspectsAndPropertiesProcessor",
    "args": {
      "properties": {
        "cm:publisher": "saidone",
        "cm:contributor": "saidone"
      },
      "aspects": [
        "cm:dublincore"
      ]
    }
  }
}